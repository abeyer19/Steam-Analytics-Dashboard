API_KEY = YOUR API KEY HERE

APP_ID_LIST_ENDPOINT = https://api.steampowered.com/IStoreService/GetAppList/v1/?last_appid=3064240&max_results=50000

APP_DETAIL_ENDPOINT = https://store.steampowered.com/api/appdetails?appids={}&cc=us

APP_REVIEWS_ENDPOINT = https://store.steampowered.com/appreviews/{}?json=1&filter=summary

APP_TAGS_ENDPOINT = https://store.steampowered.com/app/{}

APP_ACHIEVEMENTS_ENDPOINT = https://api.steampowered.com/ISteamUserStats/GetSchemaForGame/v2/?key={}&appid={}

ACHIEVEMENT_GLOBAL_PCT_ENDPOINT=https://api.steampowered.com/ISteamUserStats/GetGlobalAchievementPercentagesForApp/v2/

PLAYER_COUNT_ENDPOINT = https://api.steampowered.com/ISteamUserStats/GetNumberOfCurrentPlayers/v1/?appid=${}
